{
  "manifest_version": 3,
  "name": "Focus Bear",
  "version": "1.1",
  "description": "Hide distractions using a clean Chrome Extension.",
  "default_locale": "en",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.linkedin.com/*",
    "*://*.wikipedia.org/*",
    "*://mail.google.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "128": "icons/bearLogo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.linkedin.com/*",
        "https://*.wikipedia.org/*",
        "https://mail.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["assets/intentionPopup.css"]
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["youtube.js"]
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["linkedin.js"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["blocklist.js"]
    },
    {
      "matches": ["*://*.wikipedia.org/*"],
      "js": ["wikipedia.js", "linkpopup.js"]
    },
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["gmail.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["floatingPopup.js", "assets/*"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "icons/bearLogo.png"
  }
}
